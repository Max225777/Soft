# === Lolzteam Market API ===
# Получить токен: https://lzt.market/account/api  (scope: read+post+market)
LOLZ_API_TOKEN=

LOLZ_API_BASE_URL=https://prod-api.lzt.market/
LOLZ_API_LANG=ru
LOLZ_API_MIN_DELAY=3.0
LOLZ_API_MAX_RETRIES=3

# === 20-минутный цикл ===
CYCLE_INTERVAL_MINUTES=20
CYCLE_AUTOSTART=true

# === База данных ===
DB_PATH=data/app.db
DB_ENCRYPTED=false

# === Логирование ===
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
