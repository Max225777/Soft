# === Lolzteam Market API ===
# Получить токен: https://lzt.market/account/api  (scope: read+post+market)
LOLZ_API_TOKEN=

# Базовый URL API (менять не нужно, если Lolzteam не сменит адрес)
LOLZ_API_BASE_URL=https://prod-api.lzt.market/

# Язык ответов API: ru | en
LOLZ_API_LANG=ru

# === Ограничения API ===
# Минимальная задержка между запросами в секундах (не менее 3 по требованиям площадки)
LOLZ_API_MIN_DELAY=3.0

# Максимальное количество повторов при ошибках 5xx / 429
LOLZ_API_MAX_RETRIES=3

# === 20-минутный цикл обновления ===
# Интервал цикла в минутах
CYCLE_INTERVAL_MINUTES=20

# Автоматически запускать цикл при старте приложения: true | false
CYCLE_AUTOSTART=true

# === База данных ===
# Путь к локальной SQLite-базе
DB_PATH=data/app.db

# Шифровать БД через SQLCipher: true | false
DB_ENCRYPTED=false

# === Логирование ===
# Уровень: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
